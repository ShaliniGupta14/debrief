# --- Core ---
ENVIRONMENT=development
GIT_SHA=dev

# --- Database ---
# Async URL used by the API at runtime (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://debrief:debrief@localhost:5432/debrief
# Sync URL used by Alembic migrations only (psycopg driver)
DATABASE_URL_SYNC=postgresql+psycopg://debrief:debrief@localhost:5432/debrief

# --- Redis (rate limiting + eval job queue) ---
REDIS_URL=redis://localhost:6379/0

# --- CORS (comma-separated origins allowed to call the API from a browser) ---
CORS_ORIGINS=http://localhost:3000

# --- Rate limiting (sliding window, per project key, ingest only) ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- Judge (Day 2) ---
ANTHROPIC_API_KEY=
JUDGE_MODEL=claude-sonnet-5
JUDGE_SAMPLE_RATE=0.2

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# Public and safe to commit: the seeded demo project's key is intentionally
# read-only (mutations return 403 regardless of who holds it).
NEXT_PUBLIC_DEMO_API_KEY=sk_demo_5f3a9c7e2b1d4680a9e6c3f0b7d2e814
